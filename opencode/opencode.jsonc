{
  "$schema": "https://opencode.ai/config.json",

  // Default model for coding tasks - uses GitHub premium
  "model": "github-copilot/gemini-3.1-pro-preview",

  // Free model for lightweight tasks (titles, summaries)
  "small_model": "opencode/minimax-m2.5-free",

  "provider": {
    "github": {
      "options": {
        "timeout": 300000,
      },
    },
    // Add OpenRouter for free models
    "openrouter": {
      "options": {
        "timeout": 120000,
      },
    },
  },

  // Custom agents for different use cases
  "agent": {
    // Main coding agent - uses GitHub premium
    "build": {
      "mode": "primary",
      "description": "Full-featured development agent for coding tasks",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "temperature": 0.3,
      "color": "primary",
    },

    // Planning agent - uses free model for analysis
    "plan": {
      "mode": "primary",
      "description": "Planning and analysis without code changes",
      "model": "huggingface/moonshotai/Kimi-K2.6",
      "temperature": 0.15,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
      },
      "permission": {
        "edit": "deny",
        "bash": "deny",
      },
      "color": "accent",
    },

    // Q&A agent - uses free model for questions
    "ask": {
      "mode": "primary",
      "description": "Answers questions and provides explanations using free models",
      "model": "huggingface/moonshotai/Kimi-K2.6",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
      },
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "deny",
      },
      "color": "info",
    },

    // Exploration agent - free model for codebase exploration
    "explore": {
      "mode": "subagent",
      "description": "Fast codebase exploration and search",
      "model": "huggingface/moonshotai/Kimi-K2.6",
      "temperature": 0.1,
      "color": "success",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
      },
    },

    // General purpose subagent - uses free model
    "general": {
      "mode": "subagent",
      "description": "General-purpose tasks and research",
      "model": "google/gemini-3.1-flash-lite",
      "temperature": 0.3,
    },
    "search": {
      "mode": "subagent",
      "description": "Ultra-fast codebase grep & navigation",
      "model": "google/gemini-3.1-flash-lite",
      "temperature": 0.0,
      "color": "info",
    },

    // Commit agent - commits changes with proper format
    "commit": {
      "mode": "subagent",
      "description": "Commits git changes with conventional commit format",
      "model": "huggingface/moonshotai/Kimi-K2.6",
      "temperature": 0.1,
      "color": "warning",
    },

    "pr": {
      "mode": "subagent",
      "description": "Creates a PR and comments on the Jira ticket in plain language",
      "model": "huggingface/moonshotai/Kimi-K2.6",
      "prompt": "Use git-town diff-parent to know what changed and git-town branch to know the parent of this branch, then create a PR with the parent as the base. After creating the PR, comment on the Jira ticket the user provides explaining what was done in plain, non-technical language — as if explaining to a product manager. Keep it to 2-4 sentences.",
      "temperature": 0.1,
      "color": "info",
    },

    "review-diff": {
      "mode": "subagent",
      "description": "Reviews branch changes using git-town diff-parent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "prompt": "Use git-town diff-parent to get the diff of changes on this branch vs its parent. Review the changes for: correctness, edge cases, security issues, code quality, and consistency with existing patterns. Report findings as: Summary (one sentence), Issues (ordered by severity), Suggestions (non-blocking), and a Verdict (Approve / Request changes / Needs discussion).",
      "temperature": 0.1,
      "color": "warning",
      "tools": {
        "write": false,
        "edit": false,
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
      },
    },
  },

  // MCP servers
  "mcp": {
    "mcp": {
      "jira": {
        "type": "remote",
        "url": "https://mcp.atlassian.com/v1/sse",
        "enabled": true,
      },
    },
  },

  // Default agent is 'build' for coding
  "default_agent": "build",

  "autoupdate": true,

  "permission": {
    "bash": "allow",
    "edit": "allow",
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
  },

  "share": "manual",
}
